@model IEnumerable<lps_web_test.Domain.Entities.BookType>

@{
    ViewData["Title"] = "Book Types";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Content Header (Page header) -->
<section class="content-header">
    <h1>
        Book Types
        <small>Manage book types</small>
    </h1>
    <ol class="breadcrumb">
        <li><a href="@Url.Action("Index", "Home")"><i class="fa fa-dashboard"></i> Home</a></li>
        <li class="active">Book Types</li>
    </ol>
</section>

<!-- Main content -->
<section class="content">
    <div class="row">
        <div class="col-xs-12">
            <!-- Search Box -->
            <div class="box box-primary">
                <div class="box-header with-border">
                    <h3 class="box-title">Search & Filter</h3>
                </div>
                <div class="box-body">
                    <form asp-action="Index" method="get" class="form-inline">
                        <div class="form-group">
                            <label for="searchString">Search by Name:</label>
                            <input type="text" id="searchString" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Enter book type name..." />
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-search"></i> Search
                        </button>
                        @if (!string.IsNullOrWhiteSpace(ViewData["CurrentFilter"]?.ToString()))
                        {
                            <a asp-action="Index" class="btn btn-default">
                                <i class="fa fa-times"></i> Clear Filter
                            </a>
                        }
                    </form>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="box box-success">
                <div class="box-body">
                    <a asp-action="Create" class="btn btn-success">
                        <i class="fa fa-plus"></i> Create New Book Type
                    </a>
                    <a asp-action="ExportToExcel" asp-route-searchString="@ViewData["CurrentFilter"]" class="btn btn-info">
                        <i class="fa fa-download"></i> Export to CSV
                    </a>
                </div>
            </div>

            <!-- Data Table -->
            <div class="box box-info">
                <div class="box-header with-border">
                    <h3 class="box-title">Book Types List</h3>
                </div>
                <div class="box-body">
                    <table class="table table-bordered table-hover table-striped">
                        <thead>
                            <tr>
                                <th style="width: 50%">
                                    @Html.DisplayNameFor(model => model.BookTypeName)
                                </th>
                                <th style="width: 30%">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@Html.DisplayFor(modelItem => item.BookTypeName)</td>
                                        <td>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-xs btn-warning">
                                                <i class="fa fa-edit"></i> Edit
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-xs btn-info">
                                                <i class="fa fa-eye"></i> View
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-xs btn-danger">
                                                <i class="fa fa-trash"></i> Delete
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted">
                                        <em>No book types found.</em>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
