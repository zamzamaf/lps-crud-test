@model lps_web_test.Domain.Entities.Book

@{
    ViewData["Title"] = "Create Book";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Content Header (Page header) -->
<section class="content-header">
    <h1>
        Create Book
        <small>Add a new book to your collection</small>
    </h1>
    <ol class="breadcrumb">
        <li><a href="@Url.Action("Index", "Home")"><i class="fa fa-dashboard"></i> Home</a></li>
        <li><a href="@Url.Action("Index", "Books")">Books</a></li>
        <li class="active">Create</li>
    </ol>
</section>

<!-- Main content -->
<section class="content">
    <div class="row">
        <div class="col-md-8">
            <div class="box box-primary">
                <div class="box-header with-border">
                    <h3 class="box-title">Book Information</h3>
                </div>
                <!-- /.box-header -->
                <!-- form start -->
                <form asp-action="Create" class="form-horizontal">
                    <div class="box-body">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="form-group">
                            <label asp-for="BookTitle" class="col-sm-3 control-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="BookTitle" class="form-control" placeholder="Enter book title" required />
                                <span asp-validation-for="BookTitle" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Author" class="col-sm-3 control-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="Author" class="form-control" placeholder="Enter author name" required />
                                <span asp-validation-for="Author" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="BookTypeId" class="col-sm-3 control-label"></label>
                            <div class="col-sm-9">
                                <select asp-for="BookTypeId" class="form-control" asp-items="ViewBag.BookTypeId">
                                    <option value="">-- Select Book Type --</option>
                                </select>
                                <span asp-validation-for="BookTypeId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="ReleaseDate" class="col-sm-3 control-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="ReleaseDate" type="date" class="form-control" />
                                <span asp-validation-for="ReleaseDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="NumberOfPages" class="col-sm-3 control-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="NumberOfPages" type="number" class="form-control" placeholder="0" />
                                <span asp-validation-for="NumberOfPages" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    <!-- /.box-body -->
                    <div class="box-footer">
                        <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> Create</button>
                        <a asp-action="Index" class="btn btn-default"><i class="fa fa-times"></i> Cancel</a>
                    </div>
                    <!-- /.box-footer -->
                </form>
            </div>
            <!-- /.box -->
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
