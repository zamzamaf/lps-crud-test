@model lps_crud_test.Models.LpsDb.BookType

@{
    ViewData["Title"] = "Delete Book Type";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Content Header (Page header) -->
<section class="content-header">
    <h1>
        Delete Book Type
        <small>Confirm deletion</small>
    </h1>
    <ol class="breadcrumb">
        <li><a href="@Url.Action("Index", "Home")"><i class="fa fa-dashboard"></i> Home</a></li>
        <li><a href="@Url.Action("Index", "BookTypes")">Book Types</a></li>
        <li class="active">Delete</li>
    </ol>
</section>

<!-- Main content -->
<section class="content">
    <div class="row">
        <div class="col-md-6">
            <div class="box box-danger">
                <div class="box-header with-border">
                    <h3 class="box-title"><i class="fa fa-warning"></i> Delete Confirmation</h3>
                </div>
                <!-- /.box-header -->
                <div class="box-body">
                    <div class="alert alert-warning">
                        <strong>Warning!</strong> Are you sure you want to delete this book type? This action cannot be undone.
                    </div>

                    <h4>@Html.DisplayFor(model => model.BookTypeName)</h4>
                    <hr />

                    <dl class="dl-horizontal">
                        <dt>@Html.DisplayNameFor(model => model.BookTypeName)</dt>
                        <dd>@Html.DisplayFor(model => model.BookTypeName)</dd>

                        <dt>@Html.DisplayNameFor(model => model.IsActiveBool)</dt>
                        <dd>@(Model.IsActiveBool ? "Active" : "Inactive")</dd>
                    </dl>
                </div>
                <!-- /.box-body -->
                <div class="box-footer">
                    <form asp-action="Delete" style="display:inline;">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger"><i class="fa fa-trash"></i> Delete</button>
                    </form>
                    <a asp-action="Index" class="btn btn-default"><i class="fa fa-times"></i> Cancel</a>
                </div>
                <!-- /.box-footer -->
            </div>
            <!-- /.box -->
        </div>
    </div>
</section>
