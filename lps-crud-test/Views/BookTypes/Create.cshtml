@model lps_crud_test.Models.LpsDb.BookType

@{
    ViewData["Title"] = "Create Book Type";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Content Header (Page header) -->
<section class="content-header">
    <h1>
        Create Book Type
        <small>Add a new book type</small>
    </h1>
    <ol class="breadcrumb">
        <li><a href="@Url.Action("Index", "Home")"><i class="fa fa-dashboard"></i> Home</a></li>
        <li><a href="@Url.Action("Index", "BookTypes")">Book Types</a></li>
        <li class="active">Create</li>
    </ol>
</section>

<!-- Main content -->
<section class="content">
    <div class="row">
        <div class="col-md-6">
            <div class="box box-primary">
                <div class="box-header with-border">
                    <h3 class="box-title">Book Type Information</h3>
                </div>
                <!-- /.box-header -->
                <!-- form start -->
                <form asp-action="Create" class="form-horizontal">
                    <div class="box-body">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        
                        <div class="form-group">
                            <label asp-for="BookTypeName" class="col-sm-3 control-label"></label>
                            <div class="col-sm-9">
                                <input asp-for="BookTypeName" class="form-control" placeholder="Enter book type name" required />
                                <span asp-validation-for="BookTypeName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="IsActiveBool" class="col-sm-3 control-label">Active</label>
                            <div class="col-sm-9">
                                <input type="checkbox" asp-for="IsActiveBool" data-toggle="toggle" data-on="Active" data-off="Inactive" data-onstyle="success" data-offstyle="danger" />
                                <span asp-validation-for="IsActiveBool" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    <!-- /.box-body -->
                    <div class="box-footer">
                        <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> Create</button>
                        <a asp-action="Index" class="btn btn-default"><i class="fa fa-times"></i> Cancel</a>
                    </div>
                    <!-- /.box-footer -->
                </form>
            </div>
            <!-- /.box -->
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
