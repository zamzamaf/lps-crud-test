@model lps_crud_test.Models.LpsDb.BookType

@{
    ViewData["Title"] = "Book Type Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Content Header (Page header) -->
<section class="content-header">
    <h1>
        Book Type Details
        <small>View book type information</small>
    </h1>
    <ol class="breadcrumb">
        <li><a href="@Url.Action("Index", "Home")"><i class="fa fa-dashboard"></i> Home</a></li>
        <li><a href="@Url.Action("Index", "BookTypes")">Book Types</a></li>
        <li class="active">Details</li>
    </ol>
</section>

<!-- Main content -->
<section class="content">
    <div class="row">
        <div class="col-md-6">
            <div class="box box-info">
                <div class="box-header with-border">
                    <h3 class="box-title">@Html.DisplayFor(model => model.BookTypeName)</h3>
                </div>
                <!-- /.box-header -->
                <div class="box-body">
                    <dl class="dl-horizontal">
                        <dt>@Html.DisplayNameFor(model => model.BookTypeName)</dt>
                        <dd>@Html.DisplayFor(model => model.BookTypeName)</dd>

                        <dt>@Html.DisplayNameFor(model => model.IsActiveBool)</dt>
                        <dd>
                            @if (Model.IsActiveBool)
                            {
                                <span class="label label-success">Active</span>
                            }
                            else
                            {
                                <span class="label label-danger">Inactive</span>
                            }
                        </dd>
                    </dl>
                </div>
                <!-- /.box-body -->
                <div class="box-footer">
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning"><i class="fa fa-edit"></i> Edit</a>
                    <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger"><i class="fa fa-trash"></i> Delete</a>
                    <a asp-action="Index" class="btn btn-default"><i class="fa fa-arrow-left"></i> Back to List</a>
                </div>
                <!-- /.box-footer -->
            </div>
            <!-- /.box -->
        </div>
    </div>
</section>
